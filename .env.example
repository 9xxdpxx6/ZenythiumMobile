# Скопируйте в `.env` при необходимости. Префикс VITE_ обязателен для клиентского кода.

# --- API (см. src/config/app.config.ts) ---
# Базовый origin сервера БЕЗ пути /api/... (по умолчанию https://api.zenythium.ru)
# VITE_API_SERVER_URL=https://api.zenythium.ru
#
# Локальная разработка с Laravel (php artisan serve) без CORS:
# VITE_API_SERVER_URL=proxy
# Опционально, если Laravel не на 127.0.0.1:8000:
# VITE_PROXY_TARGET=http://127.0.0.1:8000

# Префиксы пути API (по умолчанию /api и /v1 → итог .../api/v1)
# VITE_API_PREFIX=/api
# VITE_API_VERSION=/v1

# --- Yandex SmartCaptcha (веб, прод) ---
# VITE_YANDEX_CAPTCHA_SITE_KEY=

# Режим dev/prod не задаётся через .env:
# - `npm run dev` => import.meta.env.DEV === true
# - `npm run build` => import.meta.env.PROD === true
# Не добавляйте сюда NODE_ENV=production.
#
# Примечание: semver приложения берётся из package.json при сборке (Vite define),
# не дублируйте его в .env. Android versionName обновляет `npm run version:patch|minor|major`.
