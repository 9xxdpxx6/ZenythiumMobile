<?xml version="1.0" encoding="utf-8"?>
<!-- Release / production: только TLS через доверенные системные CA, без cleartext и без user CA. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
